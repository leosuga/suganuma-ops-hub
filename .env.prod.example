# Suganuma Ops Hub — variáveis de ambiente de produção
# Copie para .env.prod e preencha os valores reais.
# NUNCA commite .env.prod no repositório.

# ── Supabase ──────────────────────────────────────────────
# Encontre em: Supabase Studio → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://api.suganuma.com.br
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key do Supabase Studio>

# Service role key — usada apenas pelo servidor (agent API).
# Encontre em: Supabase Studio → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=<service_role key do Supabase Studio>

# ── Webhooks ──────────────────────────────────────────────
# String aleatória para assinar webhooks HMAC-SHA256.
# Gere com: openssl rand -hex 32
WEBHOOK_SECRET=<string aleatória gerada com openssl rand -hex 32>
